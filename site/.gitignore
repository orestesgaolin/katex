# Files and directories created by pub.
**/doc/api/
.dart_tool/
.packages

# Conventional directory for build output.
/build/

# Generated Flutter-web output for the katex_flutter column.
# Regenerate with: cd flutter_host && flutter build web --base-href /flutter/
#   then: cp -r flutter_host/build/web web/flutter   (see README.md).
/web/flutter/
/flutter_host/build/
/flutter_host/.dart_tool/

